# ─── Required ─────────────────────────────────────────────────────────────────

# Groq API key — get it free at https://console.groq.com
# Create a Modal secret named "portfolio-secrets" and add this key
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Optional (for local development only) ───────────────────────────────────

# When running locally (not on Modal), set these so the app can find secrets
# These are NOT needed in production — Modal injects them via modal.Secret
# GROQ_API_KEY=gsk_your_groq_api_key_here  # same as above, for local testing

# ─── Frontend Configuration (set in Vercel dashboard) ────────────────────────

# The Modal-deployed URL for your backend (shown after `modal deploy`)
# Format: https://<your-workspace>--portfolio-rag-web.modal.run
# NEXT_PUBLIC_BACKEND_URL=https://your-modal-url.modal.run
